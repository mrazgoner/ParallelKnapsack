<Window x:Class="ParallelKnapsackWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ParallelKnapsackWPF.Models"
        Title="Knapsack Calculator" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Null to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Toolbar -->
            <RowDefinition Height="*"/>         <!-- Content -->
            <RowDefinition Height="Auto"/>      <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Height="48">
            <TextBlock Text="Knapsack Calculator" 
                      FontSize="18" 
                      FontWeight="SemiBold" 
                      Foreground="White"
                      VerticalAlignment="Center"
                      Margin="16,0"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>   <!-- Input -->
                <ColumnDefinition Width="2*"/>   <!-- Results -->
            </Grid.ColumnDefinitions>

            <!-- INPUT SECTION -->
            <Border Grid.Column="0" 
                   Background="White" 
                   BorderBrush="{StaticResource Gray300}" 
                   BorderThickness="1"
                   CornerRadius="4"
                   Padding="16"
                   Margin="0,0,8,0">
                <DockPanel>
                    <!-- Title -->
                    <TextBlock DockPanel.Dock="Top" 
                              Text="Input" 
                              FontSize="16" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"/>

                    <!-- Algorithm Selection -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <TextBlock Text="Algorithm:" Margin="0,0,0,4"/>
                        <ComboBox SelectedItem="{Binding SelectedAlgorithm}">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type models:AlgorithmType}">
                                    <models:AlgorithmType>Sequential</models:AlgorithmType>
                                    <models:AlgorithmType>Parallel</models:AlgorithmType>
                                    <models:AlgorithmType>AntiDiagonal</models:AlgorithmType>
                                    <models:AlgorithmType>Cuda</models:AlgorithmType>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                    </StackPanel>

                    <!-- Capacity -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                        <TextBlock Text="Capacity:" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Capacity, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Items Grid -->
                    <TextBlock DockPanel.Dock="Top" Text="Items:" Margin="0,0,0,4"/>
                    <DataGrid DockPanel.Dock="Top"
                             ItemsSource="{Binding Items}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             Height="250"
                             Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Weight" Binding="{Binding Weight}" Width="60"/>
                            <DataGridTextColumn Header="Profit" Binding="{Binding Profit}" Width="60"/>
                            <DataGridTemplateColumn Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" 
                                               Command="{Binding DataContext.RemoveItemCommand, 
                                                       RelativeSource={RelativeSource AncestorType=Window}}"
                                               CommandParameter="{Binding}"
                                               BorderThickness="0"
                                               Background="Transparent"
                                               Foreground="Red"
                                               Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Add Item Button -->
                    <Button DockPanel.Dock="Bottom"
                           Content="+ Add Item" 
                           Command="{Binding AddItemCommand}"
                           Margin="0,8,0,0"
                           Padding="8,4"/>
                </DockPanel>
            </Border>

            <!-- RESULTS SECTION -->
            <Border Grid.Column="1" 
                   Background="White" 
                   BorderBrush="{StaticResource Gray300}" 
                   BorderThickness="1"
                   CornerRadius="4"
                   Padding="16"
                   Margin="8,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" 
                              Text="Results" 
                              FontSize="16" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"/>

                    <!-- No Results Message -->
                    <TextBlock DockPanel.Dock="Top"
                              Text="Click 'Compute' to calculate results"
                              FontStyle="Italic"
                              Foreground="{StaticResource Gray500}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,100,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Result}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Results Display -->
                    <StackPanel DockPanel.Dock="Top">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Result}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Result, Converter={x:Null}}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Value:" FontWeight="Bold" Margin="0,0,16,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Result.MaxValue}" FontFamily="Consolas" FontSize="14"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Weight:" FontWeight="Bold" Margin="0,0,16,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Result.TotalWeight}" FontFamily="Consolas" FontSize="14"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Execution Time:" FontWeight="Bold" Margin="0,0,16,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" 
                                      Text="{Binding Result.ExecutionTime.TotalMilliseconds, StringFormat='{}{0:F2} ms'}" 
                                      FontFamily="Consolas" FontSize="14"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Selected Items:" FontWeight="Bold" Margin="0,0,16,8"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" 
                                      Text="{Binding Result.SelectedItems.Count}" 
                                      FontFamily="Consolas" FontSize="14"/>
                        </Grid>

                        <!-- Selected Items List -->
                        <TextBlock Text="Selected Items:" FontWeight="Bold" Margin="0,16,0,8"/>
                        <DataGrid ItemsSource="{Binding Result.SelectedItems}"
                                 AutoGenerateColumns="False"
                                 IsReadOnly="True"
                                 Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Weight" Binding="{Binding Weight}" Width="80"/>
                                <DataGridTextColumn Header="Profit" Binding="{Binding Profit}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" 
               Background="{StaticResource Gray100}" 
               BorderBrush="{StaticResource Gray300}" 
               BorderThickness="0,1,0,0"
               Height="40">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                    <ProgressBar Width="100" Height="4" IsIndeterminate="True" Margin="16,0,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Compute" 
                           Command="{Binding ComputeCommand}"
                           Background="{StaticResource PrimaryBrush}"
                           Foreground="White"
                           Padding="16,4"
                           Margin="0,0,8,0"
                           BorderThickness="0"
                           Cursor="Hand"/>
                    <Button Content="Clear" 
                           Command="{Binding ClearCommand}"
                           Padding="16,4"
                           BorderThickness="1"
                           BorderBrush="{StaticResource Gray300}"
                           Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
